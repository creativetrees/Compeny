APP_NAME="Creative Trees Group"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://creativetrees.group

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Admin panel access ──
# Comma-separated email domains allowed into /admin. Empty value = deny everyone.
PANEL_MFA_REQUIRED=true
# Admin seeding: in production `db:seed` only creates the admin when a password is set.
ADMIN_SEED_EMAIL=admin@creativetrees.group
ADMIN_SEED_PASSWORD=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database : PostgreSQL ──
# The Docker `postgres` service is published on host port 5433 (5432 is reserved
# for a native local Postgres). For a native cPanel/VPS Postgres, use 5432.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
FORWARD_DB_PORT=5433
DB_DATABASE=creative_trees
DB_USERNAME=ctg
DB_PASSWORD=

# ── Config-driven backends ──
# `database` keeps the app fully working with NO Redis running.
# Switch the three below to `redis` once Redis is available (Docker / cPanel).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# `log` disables real-time cleanly; flip to `reverb` only when realtime is needed.
# (Front-end realtime is additionally gated by VITE_ENABLE_REALTIME below.)
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail : `log` for now; flips to Mailpit (smtp 127.0.0.1:1025) when Docker is up ──
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@creativetrees.group"
MAIL_FROM_NAME="${APP_NAME}"

# ── Reverb (websockets) — values ready; activated when the package is installed ──
REVERB_APP_ID=creative-trees
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
# Front-end Echo/Pusher is bundled & connected only when this is true.
VITE_ENABLE_REALTIME=false
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
